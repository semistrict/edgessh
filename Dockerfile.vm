# VM guest rootfs image — everything a Firecracker microVM needs.
# Used by: edgessh create NAME (builds this automatically)
# The edgessh-init and edgessh-poweroff binaries are added to the rootfs
# at volume creation time, not baked into this image.
FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    htop \
    iputils-ping \
    jq \
    less \
    man-db \
    openssh-server \
    ripgrep \
    sudo \
    tmux \
    unzip \
    vim \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Set TERM, then exec bash so the user always gets bash.
RUN echo 'export TERM=xterm-256color' > /etc/profile.d/edgessh.sh && \
    echo 'export SHELL=/bin/bash' >> /etc/profile.d/edgessh.sh && \
    echo '[ "$(basename -- "$0")" != "bash" ] && [ -x /bin/bash ] && exec /bin/bash --login' >> /etc/profile.d/edgessh.sh

# Configure sshd for root login
RUN mkdir -p /run/sshd && \
    ssh-keygen -A && \
    sed -i 's/#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    echo 'root:root' | chpasswd
